# UD07 - Configurazione ambiente laboratorio
# Copiare questo file in config/ud07.env e modificare i valori.
# Non inserire segreti nel repository.

# Subscription Azure usata dal partecipante.
SUB_ID="<id-subscription>"

# Resource Group creato in UD05.
RG_NAME="rg-obs-ud05-<codice>"

# Risorse principali create o mantenute da UD05.
STORAGE_NAME="stobsud05<codice>01"
APP_NAME="app-obs-ud05-<codice>"
VM_NAME="vm01"

# Parametri per generazione traffico applicativo.
# Valori volutamente piccoli per evitare carico inutile.
APP_REQUESTS="40"
APP_404_REQUESTS="10"
STORAGE_OPS="20"
WAIT_METRICS_SECONDS="180"

# Probe VM opzionale.
# Lasciare 0 se la VM non è running o se il docente non autorizza RunCommand.
RUN_VM_PROBE="0"
VM_CPU_SECONDS="20"
COMPUTE_API_VERSION="2025-04-01"

# Parametri per attività amministrativa.
ADMIN_ROUNDS="3"
SLEEP_BETWEEN_RESOURCES="3"
SLEEP_BETWEEN_ROUNDS="10"
WAIT_ACTIVITY_LOG_SECONDS="60"

# Facoltativo: Resource ID di Log Analytics Workspace predisposto dal docente.
LAW_RESOURCE_ID=""
