  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Disponibilità dei servizi",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-products"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-products"
          },
          "expr": "up{job=~\"products-.*\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate: contesto aggregato",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 16,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-products"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-products"
          },
          "expr": "sum by (service,path,status) (rate(app_http_requests_total{path=~\"/|/(api/)?products.*|/ready\"}[1m]))",
          "legendFormat": "{{service}} {{path}} {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate frontend: individuazione del sintomo",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-products"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-products"
          },
          "expr": "(sum(rate(app_http_requests_total{service=\"products-frontend\",path=~\"/products.*\",status=~\"5..\"}[2m])) or vector(0)) / clamp_min(sum(rate(app_http_requests_total{service=\"products-frontend\",path=~\"/products.*\"}[2m])) or vector(0), 0.001)",
          "legendFormat": "frontend error rate",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latenza p95 frontend: individuazione del sintomo",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-products"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-products"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(app_http_request_duration_seconds_bucket{service=\"products-frontend\",path=~\"/products.*\"}[2m])))",
          "legendFormat": "frontend p95",
          "refId": "A"
        }
      ],
