# UD09 - Configurazione di esempio
# Copiare in config/ud09.env e valorizzare in base al proprio ambiente.

# Resource Group usato nelle UD Azure precedenti
export RG_UD05="rg-obs-ud05-<codice>"
export RG_UD08="rg-obs-ud08-<codice>"

# Log Analytics Workspace creato/usato in UD08
export LAW_NAME="law-obs-ud08-<codice>"
export LAW_RG="$RG_UD08"
export WORKSPACE_ID="<customer-id-del-law>"

# Risorse opzionali create in UD05
export STORAGE_ACCOUNT="<storage-account-name>"
export WEBAPP_NAME="<app-service-name>"
export VM_NAME="<vm-name>"
