# UD09 - Esempio variabili ambiente.
# Copiare questo file in config/ud09.env e sostituire i valori segnaposto.

# ID o nome della subscription Azure.
SUB_ID="<subscription-id-o-nome>"

# Resource Group che contiene il Log Analytics Workspace.
RG_NAME="<resource-group>"

# Nome del Log Analytics Workspace.
LAW_NAME="<log-analytics-workspace>"

# Customer ID del workspace, usato dal comando az monitor log-analytics query.
WORKSPACE_ID="<workspace-customer-id>"
