// UD09 - AzureDiagnostics fallback: utile solo in ambienti che inviano ancora resource log nella tabella legacy.
AzureDiagnostics
| where TimeGenerated > ago(24h)
| where Level in ("Error", "Critical") or ResultType has "Fail" or tostring(httpStatusCode_d) startswith "5"
| summarize Eventi=count() by ResourceProvider, Resource, Category, bin(TimeGenerated, 1h)
| sort by TimeGenerated desc, Eventi desc
