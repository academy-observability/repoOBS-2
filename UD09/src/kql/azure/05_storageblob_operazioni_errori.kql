// UD09 - StorageBlobLogs: operazioni Blob e stato.
// Prerequisito: Diagnostic settings del Blob service verso LAW e traffico Blob generato dopo il collegamento.
StorageBlobLogs
| where TimeGenerated > ago(24h)
| summarize
    Operazioni=count(),
    Errori=countif(toint(StatusCode) >= 400)
  by OperationName, AccountName
| extend ErrorRate = iff(Operazioni == 0, 0.0, round(100.0 * Errori / Operazioni, 2))
| sort by ErrorRate desc, Errori desc

