  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Target UP frontend/backend",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-products"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-products"
          },
          "expr": "up{job=~\"products-.*\"}",
          "legendFormat": "{{service}} {{path}} {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate per path",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 16,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-products"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-products"
          },
          "expr": "sum by (service,path,status) (rate(app_http_requests_total{path=~\"/|/products.*|/ready\"}[1m]))",
          "legendFormat": "{{service}} {{path}} {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
