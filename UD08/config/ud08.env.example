# UD08 - Configurazione locale del laboratorio
# Copiare questo file in config/ud08.env e modificare i valori.

# ID della subscription Azure usata nel laboratorio.
# Esempio: SUB_ID="00000000-0000-0000-0000-000000000000"
SUB_ID=""

# Resource Group in cui si trova o verrà creato il Log Analytics Workspace.
# È possibile usare il Resource Group delle UD precedenti oppure un Resource Group dedicato UD08.
RG="rg-obs-ud08-<codice>"

# Regione Azure usata per il workspace.
LOCATION="westeurope"

# Nome del Log Analytics Workspace della UD08.
LAW="law-obs-ud08-<codice>"

# customerId del workspace.
# Lasciare vuoto fino al recupero con Azure CLI.
WORKSPACE_ID=""
