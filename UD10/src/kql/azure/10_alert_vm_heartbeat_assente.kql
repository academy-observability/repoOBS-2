// UD10 - Alert candidato: VM senza heartbeat recente.
// La soglia va adattata all'ambiente. Esempio didattico: assenza oltre 15 minuti.

Heartbeat
| summarize ultimo_heartbeat=max(TimeGenerated) by Computer
| extend minuti_da_ultimo_heartbeat = datetime_diff("minute", now(), ultimo_heartbeat)
| where minuti_da_ultimo_heartbeat > 15
| project Computer, ultimo_heartbeat, minuti_da_ultimo_heartbeat
