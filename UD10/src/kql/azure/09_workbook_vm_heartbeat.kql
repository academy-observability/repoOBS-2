// UD10 - Workbook: ultimo heartbeat VM.
// Prerequisito: VM monitorata con Azure Monitor Agent / DCR o VM Insights.

Heartbeat
| where TimeGenerated > ago(24h)
| summarize ultimo_heartbeat=max(TimeGenerated), heartbeat=count() by Computer
| extend minuti_da_ultimo_heartbeat = datetime_diff("minute", now(), ultimo_heartbeat)
| order by minuti_da_ultimo_heartbeat desc
